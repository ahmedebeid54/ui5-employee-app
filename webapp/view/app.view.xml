<mvc:View controllerName="exercise.controller.App"
xmlns:mvc="sap.ui.core.mvc" 
          xmlns="sap.m"
          xmlns:core="sap.ui.core"
          >
          <Text text="Hello World !!" width="100%"></Text>
          <ComboBox 
          id="comboBox" placeholder="Select an option"  change="onSelectionChange">
        <items>
            <core:Item key="OPTION_A" text="Option A Display Text"/>
            <core:Item key="OPTION_B" text="Option B Display Text"/>
            <core:Item key="OPTION_C" text="Option C Display Text"/>
        </items></ComboBox>
        <Button text="Submit" press="onSubmitPress"></Button>
  </mvc:View>        